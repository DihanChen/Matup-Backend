PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Resend
RESEND_API_KEY=your_new_key
RESEND_FROM=MatUp <onboarding@resend.dev>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: used by seed:courts when geocoding a city/query into bounds
MAPTILER_API_KEY=

# Optional: comma-separated fallback Overpass endpoints for court imports
OVERPASS_API_URLS=https://overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
